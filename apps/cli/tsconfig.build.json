{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "./.tsbuildinfo",
    "paths": {
      "@frites/core": ["../../packages/core/dist/index.d.ts"],
      "@frites/agents": ["../../packages/agents/dist/index.d.ts"],
      "@frites/isolation": ["../../packages/isolation/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["test/**", "dist/**"]
}
