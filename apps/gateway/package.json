{
  "name": "@frites/gateway",
  "version": "0.0.0",
  "description": "Transparent model-provider gateway for frites",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
