{
  "name": "frites",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm --filter @frites/core build && pnpm --filter @frites/agents build && pnpm --filter @frites/isolation build && pnpm --filter @frites/gateway build && pnpm --filter @frites/cli build",
    "clean": "rm -rf apps/*/dist packages/*/dist apps/*/*.tsbuildinfo packages/*/*.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "mcp": "tsx apps/mcp/src/index.ts",
    "gateway": "tsx apps/gateway/src/index.ts",
    "frites": "tsx apps/cli/src/index.ts",
    "eval": "tsx eval/value-gate.ts",
    "bench": "tsx eval/bench-matrix.ts",
    "wbench": "tsx eval/worktree-matrix.ts",
    "changeset": "changeset",
    "version:packages": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm build && node scripts/publish.mjs",
    "release:dry": "pnpm build && node scripts/publish.mjs --dry-run"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
